# Azure FinOps Agent - Production Environment Variables
# Set these in your Azure App Service or CI pipeline.
# .NET maps double-underscore (__) to config sections automatically.

# Microsoft Entra ID OAuth (Multi-Tenant - for Azure tenant data access)
Microsoft__ClientId=your_microsoft_client_id
Microsoft__ClientSecret=your_microsoft_client_secret
Microsoft__TenantId=common

# Azure OpenAI
AzureOpenAI__Endpoint=your_azure_openai_endpoint
AzureOpenAI__DeploymentName=your_deployment_name

# Application Insights (Optional — for observability)
ApplicationInsights__ConnectionString=your_app_insights_connection_string

# Build metadata (set by CI or deploy.ps1)
BUILD_SHA=dev
BUILD_NUMBER=0
